{
  "name": "@fitconnect/shared",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./types/*": "./src/types/*.ts",
    "./firebase/*": "./src/firebase/*.ts",
    "./stores/*": "./src/stores/*.ts",
    "./payments/*": "./src/payments/*.ts"
  },
  "scripts": {
    "build": "echo 'No build step — consumed as TypeScript source'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "firebase": "^12.7.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^3.2.1"
  }
}
