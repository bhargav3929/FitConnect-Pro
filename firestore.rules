rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    // - Read: owner can read own profile; admin can read all (for member management)
    // - Create: authenticated users can create their own profile
    // - Update: only the owner can update their own profile (non-subscription fields)
    // - Subscription and stats fields are updated by Cloud Functions (Admin SDK bypasses rules)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // Classes collection
    // - Read: any authenticated user can browse classes
    // - Write: admin only (via Cloud Functions with Admin SDK)
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Bookings collection
    // - Read: owner can read their own bookings; admin can read all
    // - Create/Update/Delete: handled exclusively by Cloud Functions (Admin SDK)
    // - Client-side writes are blocked to ensure transactional integrity
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Payments collection
    // - Read: owner can read their own payments; admin can read all
    // - Write: handled exclusively by API routes (Admin SDK bypasses rules)
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Trainers collection
    // - Read: any authenticated user
    // - Write: admin only
    match /trainers/{trainerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Gym Centers (single facility)
    // - Read: public (for marketing/info pages)
    // - Write: admin only
    match /gymCenters/{gymId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Subscription Plans
    // - Read: public (for pricing page)
    // - Write: admin only
    match /subscriptionPlans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Intro class leads (public form submissions)
    // - Create: anyone (unauthenticated form submissions allowed)
    // - Read/Update/Delete: admin only
    match /introClassLeads/{leadId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'phone'])
                    && request.resource.data.name is string
                    && request.resource.data.email is string
                    && request.resource.data.phone is string;
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Waitlist (founding membership interest)
    // - Create: anyone (no auth required)
    // - Read/Update/Delete: admin only
    match /waitlist/{entryId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'phone', 'email'])
                    && request.resource.data.name is string
                    && request.resource.data.phone is string
                    && request.resource.data.email is string;
      allow read, update, delete: if isAdmin();
    }

    // Admins collection
    // - Read/Write: admin only
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Feedback collection (public form submissions)
    // - Create: anyone (unauthenticated form submissions allowed)
    // - Read/Update/Delete: admin only
    match /feedback/{docId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'message', 'rating'])
                    && request.resource.data.name is string
                    && request.resource.data.message is string
                    && request.resource.data.rating is int;
      allow read, update, delete: if isAdmin();
    }
  }
}
